{
  "Umbraco": {
    "CMS": {
      "Unattended": {
        "InstallUnattended": true,
        "UnattendedUserName": "Admin",
        "UnattendedUserEmail": "admin@example.com",
        "UnattendedUserPassword": "Password123!"
      },
      "Global": {
        "Id": "7d41624c-7b0e-48e5-b2e9-ff350fe027f3",
        "ConfigurationStatus": "13.3.0",
        "DefaultUILanguage": "en-US"
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true
      },
      "DeliveryApi": {
        "Enabled": true,
        "PublicAccess": true,
        "Content": {
          "PublicAccess": true
        },
        "Media": {
          "PublicAccess": true
        }
      }
    }
  },
  "uSync": {
    "Settings": {
      "ImportAtStartup": "All",
      "ImportOnFirstBoot": true,
      "ExportOnSave": "All"
    }
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "Data Source=/app/umbraco/Data/Umbraco.sqlite;Cache=Shared;Foreign Keys=True;Mode=ReadWriteCreate;",
    "umbracoDbDSN_ProviderName": "Microsoft.Data.Sqlite"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
